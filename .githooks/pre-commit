#!/bin/sh
set -eu

unmerged_paths="$(git diff --name-only --diff-filter=U)"
unmerged_index="$(git ls-files -u)"

if [ -n "$unmerged_paths" ] || [ -n "$unmerged_index" ]; then
  echo "Resolve every merge conflict before committing changes." >&2
  [ -n "$unmerged_paths" ] && echo "$unmerged_paths" >&2
  exit 1
fi

root="$(git rev-parse --show-toplevel)"
worktrees="$(git worktree list --porcelain | sed -n 's/^worktree //p')"

if ! printf '%s\n' "$worktrees" | grep -F -x -- "$root" >/dev/null; then
  echo "Commit only from a live registered worktree; current: $root; registered: ${worktrees:-none}" >&2
  exit 1
fi

branch="$(git branch --show-current)"
case "$branch" in
  agent/*) node "$root/scripts/writer-lease-guard.mjs" ;;
esac
