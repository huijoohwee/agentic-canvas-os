{
  "name": "agentic-canvas-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker product tier that calls the knowgrph control plane over MCP and embeds the live knowgrph canvas. Holds no model provider keys.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "agent-definitions:check": "node --test __tests__/agent-definitions.test.mjs",
    "agent-orchestration:check": "node --test __tests__/agent-orchestration.test.mjs",
    "agent-team:check": "node --test __tests__/agent-team-contract.test.mjs && node ./scripts/agent-team-contract.mjs",
    "agent-live-provider:check": "node --test __tests__/openai-agent-live-proof.test.mjs",
    "agent-live-provider:proof": "node ./scripts/live-agent-provider-proof.mjs",
    "agent-runtime-composition:check": "node --test __tests__/agent-runtime-composition.test.mjs",
    "autonomous-runtime:check": "node --test __tests__/autonomous-runtime.test.mjs __tests__/agent-api-app.test.mjs __tests__/cloudflare-worker.test.mjs",
    "agent-swarm:check": "node --test __tests__/agent-swarm.test.mjs __tests__/durable-agent-state.test.mjs __tests__/agent-api-app.test.mjs __tests__/cloudflare-worker.test.mjs",
    "agent-toolkit:check": "node --test __tests__/agent-toolkit.test.mjs __tests__/durable-agent-state.test.mjs __tests__/agent-api-app.test.mjs __tests__/cloudflare-worker.test.mjs",
    "application-composition-contract:check": "node --test __tests__/application-composition-contract.test.mjs",
    "build": "npm run web:build",
    "cache-context:check": "node --test __tests__/cache-context.test.mjs",
    "programmatic-tool-calling:check": "node --test __tests__/programmatic-tool-calling.test.mjs",
    "progressive-agents:check": "node --test __tests__/progressive-agents.test.mjs",
    "running-agents:check": "node --test __tests__/running-agents.test.mjs",
    "sandbox-agents:check": "node --test __tests__/sandbox-agents.test.mjs",
    "sandbox-provider:check": "node --test __tests__/sandbox-agents.test.mjs __tests__/docker-sandbox-provider.test.mjs",
    "sandbox-docker:check": "node ./scripts/check-docker-sandbox-provider.mjs",
    "reasoning-continuity:check": "node --test __tests__/reasoning-continuity.test.mjs",
    "tool-search:check": "node --test __tests__/tool-search.test.mjs",
    "xr-invocation-contract:check": "node --test __tests__/xr-invocation-contract.test.mjs && npm run docs:check",
    "game-mode-invocation-contract:check": "node --test __tests__/game-mode-invocation-contract.test.mjs && npm run docs:check",
    "check": "npm test && npm run web:build && npm run docs:check",
    "function-calling:check": "node --test __tests__/function-calling.test.mjs",
    "function-gateway:check": "node --test __tests__/function-calling.test.mjs __tests__/function-calling-continuation.test.mjs __tests__/function-execution-receipts.test.mjs __tests__/openai-function-gateway.test.mjs __tests__/knowgrph-mcp-client.test.mjs",
    "function-gateway:cross-repo-proof": "node ./scripts/function-gateway-run-note-proof.mjs",
    "function-gateway:deploy:dev": "npm run web:build && node ./scripts/deploy-dev-function-gateway.mjs",
    "function-gateway:live-proof": "node ./scripts/live-function-run-note-proof.mjs",
    "function-gateway:live-proof:check": "node --test __tests__/live-function-run-note-proof.test.mjs",
    "guardrails-human-review:check": "node --test __tests__/guardrails-human-review.test.mjs __tests__/durable-agent-state.test.mjs",
    "runtime-readiness-contract:check": "node --test __tests__/production-runtime-readiness-contract.test.mjs",
    "model-providers:check": "node --test __tests__/model-providers.test.mjs",
    "prompt-preset-contract:check": "node --test __tests__/prompt-preset-contract.test.mjs && npm run docs:check",
    "probe-tree-contract:check": "node --test __tests__/probe-tree-contract.test.mjs && npm run docs:check",
    "collaboration:gate": "node ./scripts/collaboration-gate.mjs",
    "collab:test": "node --test __tests__/collab-room.test.mjs",
    "device:complete": "node ./scripts/device-branch.mjs complete",
    "device:end": "node ./scripts/device-branch.mjs end",
    "device:heartbeat": "node ./scripts/device-branch.mjs heartbeat",
    "device:park": "node ./scripts/device-branch.mjs park",
    "device:review": "node ./scripts/device-branch.mjs review",
    "runtime:local:ensure": "node ./scripts/local-runtime.mjs ensure",
    "runtime:local:status": "node ./scripts/local-runtime.mjs status",
    "runtime:local:stop": "node ./scripts/local-runtime.mjs stop",
    "turn:end": "node ./scripts/local-runtime.mjs turn-end",
    "device:start": "node ./scripts/device-branch.mjs start",
    "device:publish": "node ./scripts/device-branch.mjs publish",
    "device:integrate": "node ./scripts/device-branch.mjs integrate",
    "device:resume": "node ./scripts/device-branch.mjs resume",
    "worktree:lifecycle:check": "node ./scripts/worktree-lifecycle.mjs check",
    "worktree:lifecycle:cleanup": "node ./scripts/worktree-lifecycle.mjs cleanup",
    "dev": "npm run cloudflare:dev",
    "docs:check": "node ./scripts/docs-contract.mjs",
    "instruction-audit:check": "node --test __tests__/instruction-audit.test.mjs && node ./scripts/instruction-audit.mjs",
    "instruction-quality:check": "node --test __tests__/instruction-task-quality.test.mjs && node ./scripts/instruction-task-quality.mjs --validate-suite",
    "instruction-quality:evaluate": "node ./scripts/instruction-task-quality.mjs",
    "skill-evolution:check": "node --test __tests__/skill-evolution-contract.test.mjs __tests__/knowgrph-mcp-client.test.mjs && node ./scripts/skill-evolution-contract.mjs",
    "managed-implementation-runs:check": "node --test __tests__/managed-implementation-runs-contract.test.mjs __tests__/device-branch-cli.test.mjs __tests__/device-command-result.test.mjs __tests__/device-integrate.test.mjs __tests__/device-park-stash.test.mjs __tests__/device-park.test.mjs __tests__/device-resume.test.mjs __tests__/device-review-resume-recovery.test.mjs __tests__/device-review.test.mjs __tests__/device-start.test.mjs __tests__/local-runtime.test.mjs __tests__/task-worktree-provision.test.mjs",
    "doctor": "node ./scripts/doctor.mjs",
    "durable-agent-state:check": "node --test __tests__/durable-agent-state.test.mjs",
    "git:configure": "git config core.hooksPath .githooks",
    "github:configure": "node ./scripts/configure-github.mjs",
    "smoke": "node ./scripts/smoke.mjs",
    "sync:live": "node ./scripts/live-sync.mjs",
    "sync:workspace": "node ./scripts/workspace-sync.mjs",
    "sync:workspace:watch": "node ./scripts/workspace-sync.mjs --watch",
    "test": "node --test __tests__/*.test.mjs",
    "web:build": "node web/build.mjs",
    "cloudflare:dev": "npm run web:build && wrangler dev"
  },
  "devDependencies": {
    "wrangler": "4.113.0"
  },
  "overrides": {
    "sharp": "0.35.3"
  }
}
