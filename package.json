{
  "name": "agentic-canvas-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker product tier that calls the knowgrph control plane over MCP and embeds the live knowgrph canvas. Holds no model provider keys.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "agent-definitions:check": "node --test __tests__/agent-definitions.test.mjs",
    "agent-orchestration:check": "node --test __tests__/agent-orchestration.test.mjs",
    "agent-live-provider:check": "node --test __tests__/openai-agent-live-proof.test.mjs",
    "agent-live-provider:proof": "node ./scripts/live-agent-provider-proof.mjs",
    "agent-runtime-composition:check": "node --test __tests__/agent-runtime-composition.test.mjs",
    "build": "npm run web:build",
    "cache-context:check": "node --test __tests__/cache-context.test.mjs",
    "programmatic-tool-calling:check": "node --test __tests__/programmatic-tool-calling.test.mjs",
    "running-agents:check": "node --test __tests__/running-agents.test.mjs",
    "sandbox-agents:check": "node --test __tests__/sandbox-agents.test.mjs",
    "sandbox-provider:check": "node --test __tests__/sandbox-agents.test.mjs __tests__/docker-sandbox-provider.test.mjs",
    "sandbox-docker:check": "node ./scripts/check-docker-sandbox-provider.mjs",
    "reasoning-continuity:check": "node --test __tests__/reasoning-continuity.test.mjs",
    "tool-search:check": "node --test __tests__/tool-search.test.mjs",
    "check": "npm test && npm run web:build && npm run docs:check",
    "function-calling:check": "node --test __tests__/function-calling.test.mjs",
    "function-gateway:check": "node --test __tests__/function-calling.test.mjs __tests__/openai-function-gateway.test.mjs",
    "model-providers:check": "node --test __tests__/model-providers.test.mjs",
    "prompt-preset-contract:check": "node --test __tests__/prompt-preset-contract.test.mjs && npm run docs:check",
    "probe-tree-contract:check": "node --test __tests__/probe-tree-contract.test.mjs && npm run docs:check",
    "collaboration:gate": "node ./scripts/collaboration-gate.mjs",
    "collab:test": "node --test __tests__/collab-room.test.mjs",
    "device:complete": "node ./scripts/device-branch.mjs complete",
    "device:end": "node ./scripts/device-branch.mjs end",
    "device:heartbeat": "node ./scripts/device-branch.mjs heartbeat",
    "device:park": "node ./scripts/device-branch.mjs park",
    "device:start": "node ./scripts/device-branch.mjs start",
    "device:publish": "node ./scripts/device-branch.mjs publish",
    "device:resume": "node ./scripts/device-branch.mjs resume",
    "dev": "npm run cloudflare:dev",
    "docs:check": "node ./scripts/docs-contract.mjs",
    "instruction-audit:check": "node --test __tests__/instruction-audit.test.mjs && node ./scripts/instruction-audit.mjs",
    "instruction-quality:check": "node --test __tests__/instruction-task-quality.test.mjs && node ./scripts/instruction-task-quality.mjs --validate-suite",
    "instruction-quality:evaluate": "node ./scripts/instruction-task-quality.mjs",
    "doctor": "node ./scripts/doctor.mjs",
    "git:configure": "git config core.hooksPath .githooks",
    "github:configure": "node ./scripts/configure-github.mjs",
    "rollback": "wrangler rollback",
    "smoke": "node ./scripts/smoke.mjs",
    "sync:live": "node ./scripts/live-sync.mjs",
    "test": "node --test __tests__/*.test.mjs",
    "web:build": "node web/build.mjs",
    "cloudflare:dev": "npm run web:build && wrangler dev",
    "cloudflare:deploy": "npm run web:build && wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "4.110.0"
  }
}
